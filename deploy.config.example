# Copy this file to "deploy.config" and edit the values, then run ./install.sh
#
#   cp deploy.config.example deploy.config
#   nano deploy.config
#   sudo ./install.sh
#
# Lines are plain shell variable assignments (no spaces around "=").

# Domain name that will point at this server (REQUIRED).
# Make sure its DNS A/AAAA record already points to this machine's public IP.
DOMAIN="example.com"

# Email used by Let's Encrypt for registration and renewal warnings (REQUIRED).
LETSENCRYPT_EMAIL="admin@example.com"

# Also include the www. sub-domain in the certificate? ("true" or "false").
# Only enable this if www.<DOMAIN> also points at this server.
INCLUDE_WWW="false"

# Local port the Node app listens on. NGINX reverse-proxies to this.
# (Matches the default in build-your-own-game/server.mjs.)
APP_PORT="3848"

# OS user the systemd service runs as. The app is copied to /opt and runs as
# this dedicated, locked-down system user (created automatically if missing).
# Usually no need to change this.
#SERVICE_USER="museumapp"
